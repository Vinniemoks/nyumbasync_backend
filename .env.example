# NyumbaSync Backend — environment variables
# Copy to .env and fill in. NEVER commit real values.
# Database setup (Atlas, local, Docker) is documented in ../DATABASE.md

# --- Required ---
NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb://localhost:27017/nyumbasync
JWT_SECRET=generate_a_random_string_of_at_least_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# WebSocket CORS origin (used by Socket.IO server)
CORS_ORIGIN=

# --- CORS / clients ---
# Comma-separated list of allowed origins (web, desktop, mobile dev hosts)
ALLOWED_ORIGINS=http://localhost:5000
CLIENT_URL=http://localhost:5000

# --- Email (SendGrid or SMTP) ---
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@nyumbasync.com
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# --- M-Pesa (Daraja) ---
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Public HTTPS URL Safaricom POSTs STK results to. Must match the mounted
# route; leave blank to use the server default (/api/v1/payments/mpesa-callback).
MPESA_CALLBACK_URL=
# C2B Paybill fallback (used when STK push fails). C2B shortcode defaults to
# MPESA_SHORTCODE. Validation/Confirmation URLs are registered with Safaricom
# (POST /payments/mpesa/c2b/validation and /confirmation). TTL = minutes the
# generated account number stays valid before expiry + auto-reversal.
MPESA_C2B_SHORTCODE=
MPESA_VALIDATION_URL=
MPESA_CONFIRMATION_URL=
MPESA_C2B_TTL_MINUTES=10
# Reversal initiator — required to auto-refund payments made after expiry.
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=

# --- Bank transfer (manual confirmation) ---
# Fallback business account shown to tenants when a landlord has no bank account
# on their profile. How many hours a bank-payment reference stays valid.
BANK_NAME=
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=
BANK_TTL_HOURS=48

# --- Card payments (Paystack hosted 3-D Secure) ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CURRENCY=KES
# Where the gateway returns the payer after checkout (your web app).
CARD_RETURN_URL=

# --- SMS / WhatsApp (Twilio) ---
# SMS + WhatsApp reminders use Twilio. WhatsApp needs an approved/sandbox sender.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=

# --- SMS (Africa's Talking) ---
AT_USERNAME=
AT_API_KEY=

# --- Optional integrations (features degrade gracefully when unset) ---
REDIS_URL=
SEARCH_PROVIDER_URL=
SEARCH_USERNAME=
SEARCH_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BACKUP_BUCKET=
SENTRY_DSN=

# --- Tuning ---
CLUSTER_MODE=false
LOG_LEVEL=info
BCRYPT_SALT_ROUNDS=10
MAX_PAYLOAD_SIZE=50mb

# Separate secret for refresh tokens (falls back to JWT_SECRET when unset)
JWT_REFRESH_SECRET=
